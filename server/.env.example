# Copy this file to server/.env and update the values for your setup.
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/do_not_disturb
JWT_SECRET=please-change-me-access-secret
JWT_REFRESH_SECRET=please-change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
VERIFICATION_CODE_TTL_SECONDS=300
